#include <iostream>
using namespace std;

class Persona {
private:
    char nombre[40];
    int edad;

public:
    void inicializar();
    void imprimir();
    void esMayorEdad();
};

void Persona::inicializar()
{
    cout << "Ingrese nombre: ";
    cin.getline(nombre,40);

    cout << "Ingrese edad: ";
    cin >> edad;
    cin.ignore();
}

void Persona::imprimir()
{
    cout << "Nombre: " << nombre << endl;
    cout << "Edad: " << edad << endl;
}

void Persona::esMayorEdad()
{
    if(edad >= 18)
        cout << "Es mayor de edad." << endl;
    else
        cout << "No es mayor de edad." << endl;
}

int main()
{
    Persona persona1;
    Persona persona2;

    persona1.inicializar();
    persona2.inicializar();

    persona1.imprimir();
    persona1.esMayorEdad();

    persona2.imprimir();
    persona2.esMayorEdad();

    return 0;
}
