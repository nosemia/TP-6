#include <iostream>
using namespace std;

class Cuadrado {
private:
    int lado;

public:
    void cargar();
    void perimetro();
    void superficie();
};

void Cuadrado::cargar()
{
    cout << "Ingrese el lado: ";
    cin >> lado;
}

void Cuadrado::perimetro()
{
    cout << "Perimetro: " << lado * 4 << endl;
}

void Cuadrado::superficie()
{
    cout << "Superficie: " << lado * lado << endl;
}

int main()
{
    Cuadrado c;

    c.cargar();
    c.perimetro();
    c.superficie();

    return 0;
}
