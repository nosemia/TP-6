#include <iostream>
using namespace std;

class Empleado {
private:
    char nombre[40];
    float sueldo;

public:
    void cargar();
    void imprimir();
    void pagaImpuestos();
};

void Empleado::cargar()
{
    cout << "Ingrese nombre: ";
    cin.getline(nombre,40);

    cout << "Ingrese sueldo: ";
    cin >> sueldo;
}

void Empleado::imprimir()
{
    cout << "Nombre: " << nombre << endl;
    cout << "Sueldo: " << sueldo << endl;
}

void Empleado::pagaImpuestos()
{
    if(sueldo > 3000)
        cout << "Debe pagar impuestos." << endl;
    else
        cout << "No debe pagar impuestos." << endl;
}

int main()
{
    Empleado empleado1;

    empleado1.cargar();
    empleado1.imprimir();
    empleado1.pagaImpuestos();

    return 0;
}
