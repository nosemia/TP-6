#include <iostream>
using namespace std;

class Operaciones {
private:
    int valor1, valor2;

public:
    void cargar();
    void suma();
    void resta();
    void multiplicacion();
    void division();
};

void Operaciones::cargar()
{
    cout << "Ingrese primer valor: ";
    cin >> valor1;

    cout << "Ingrese segundo valor: ";
    cin >> valor2;
}

void Operaciones::suma()
{
    cout << "Suma: " << valor1 + valor2 << endl;
}

void Operaciones::resta()
{
    cout << "Resta: " << valor1 - valor2 << endl;
}

void Operaciones::multiplicacion()
{
    cout << "Multiplicacion: " << valor1 * valor2 << endl;
}

void Operaciones::division()
{
    cout << "Division: " << valor1 / valor2 << endl;
}

int main()
{
    Operaciones op;

    op.cargar();
    op.suma();
    op.resta();
    op.multiplicacion();
    op.division();

    return 0;
}
